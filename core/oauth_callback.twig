<!DOCTYPE html>
<html>
    <head>
        <title>{{ Lang.get('core.oauth') }}</title>
        <meta charset="utf-8">
    </head>
    <body>
        {% if data is not empty %}
            <noscript>JavaScript is required to use this page!</noscript>
            <p>Authentication complete. You may now close this window.</p>
            <script>
                window.onload = function () {
                    var channel = new BroadcastChannel('sp_oauth_channel');
                    channel.postMessage({ type: 'spOAuthCallback', data: "{{ data|json_encode|e('js') }}" });
                    channel.close();
                    window.close();
                }
            </script>
        {% else %}
            <h1>{{ Lang.get('messages.error') }} - {{ error }}</h1>
            {% if error_description is not empty %}
                <p>{{ error_description }}</p>
            {% endif %}
            <script>
                window.onload = function () {
                    var channel = new BroadcastChannel('sp_oauth_channel');
                    channel.postMessage({ type: 'spOAuthError' });
                    channel.close();
                }
            </script>
        {% endif %}
    </body>
</html>