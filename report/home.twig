{% extends parent_template %}

{% block sidebar %}
    {% include 'operator.' ~ template ~ '.report.sidebar' %}
{% endblock %}

{% block title %}
    {{ Lang.choice('report.report', 2) }}
{% endblock %}

{% block content %}

    <hr />

    {% for report in reports %}
        <div class="sp:mt-6 sp:mb-3 sp:flex sp:items-center sp:gap-x-3">
            <div class="sp:flex-none">
                {{ report.icon|raw }}
            </div>
            <h3 class="sp:m-0">{{ report.name }}</h3>
        </div>

        <div class="sp:flex sp:flex-wrap sp:-m-1.5">
            {% for dashboard in report.dashboards %}
                <div class="sp:w-full sp:p-1.5 sp:sm:w-1/2 sp:lg:w-1/3">
                    <a class="sp:block sp:h-full sp:p-4 sp:border sp:border-tertiary sp:rounded sp:hover:shadow" href="{{ route('report.operator.dashboard', {'name': dashboard.uriKey()}) }}">
                        <h4 class="sp:mt-0">{{ dashboard.name() }}</h4>
                        <div class="sp-description">{{ dashboard.description() }}</div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

{% endblock %}
